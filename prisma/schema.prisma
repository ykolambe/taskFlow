generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Platform ───────────────────────────────────────────────────────────────

model PlatformOwner {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  scheduledPushes ScheduledPush[]

  @@map("platform_owners")
}

// ─── Companies (Tenants) ────────────────────────────────────────────────────

model Company {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logoUrl     String?
  domain      String?
  /// Free-form brand / audience description for Content Studio AI (e.g. coaching vertical, tone).
  contentBrandBrief           String?
  /// Primary public website URL; server may fetch text to ground idea generation.
  contentBrandWebsite         String?
  /// Optional competitor or reference URLs / notes (newline-separated URLs or prose).
  contentBrandCompetitorNotes String?
  isActive    Boolean  @default(true)
  modules     String[] @default(["tasks", "team", "org", "approvals"])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users            User[]
  roleLevels       RoleLevel[]
  tasks            Task[]
  recurringTasks   RecurringTask[]
  approvalRequests ApprovalRequest[]
  taskRequests     TaskRequest[]
  ideas            Idea[]
  taskStatuses     TaskStatusConfig[]
  billing          CompanyBilling?
  userReminders    UserReminder[]
  channels         Channel[]
  channelMessages  ChannelMessage[]
  channelMembers   ChannelMember[]
  calendars        CalendarCollection[]
  calendarEntries  CalendarEntry[]
  infraConfig      TenantInfraConfig?
  provisioningJobs TenantProvisioningJob[]
  aiUsageLogs      TenantAiUsageLog[]
  userReportingLinks UserReportingLink[]
  hierarchyTiers   CompanyHierarchyTier[]
  scheduledPushes  ScheduledPush[]

  @@map("companies")
}

enum UiTheme {
  LIGHT
  DARK
}

enum UiFontScale {
  SMALL
  MEDIUM
  LARGE
  XL
}

// ─── Role Levels (Hierarchy) ────────────────────────────────────────────────

model RoleLevel {
  id        String  @id @default(cuid())
  companyId String
  name      String
  level     Int     // 1 = top of hierarchy, higher number = lower
  color     String  @default("#6366f1")
  canApprove Boolean @default(true)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  users   User[]
  channels Channel[]

  @@unique([companyId, name])
  @@index([companyId, level])
  @@map("role_levels")
}

/// Per numeric hierarchy tier (multiple named roles may share the same level, e.g. CEO + CTO at level 2).
model CompanyHierarchyTier {
  id               String  @id @default(cuid())
  companyId        String
  level            Int
  /// When true, all users whose role is assigned this hierarchy level get AI add-on access (if company billing includes AI).
  defaultAiAddon   Boolean @default(false)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, level])
  @@map("company_hierarchy_tiers")
}

// ─── Users ──────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  companyId    String
  roleLevelId  String?
  email        String
  username     String
  passwordHash String
  firstName    String
  lastName     String
  avatarUrl    String?
  bio          String?
  phone        String?
  isSuperAdmin Boolean  @default(false)
  /// Default company bootstrap super admin; excluded from team/org lists and approver chains.
  isTenantBootstrapAccount Boolean @default(false)
  aiLeaderQaEnabled Boolean @default(false)
  /// Per-user grant when company has purchased the chat add-on (Pro).
  chatAddonAccess     Boolean @default(true)
  recurringAddonAccess Boolean @default(true)
  aiAddonAccess       Boolean @default(false)
  contentStudioAddonAccess Boolean @default(false)
  isActive     Boolean  @default(true)
  uiTheme      UiTheme    @default(DARK)
  uiFontScale  UiFontScale @default(MEDIUM)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  roleLevel RoleLevel? @relation(fields: [roleLevelId], references: [id])
  /// People this user reports to (multiple allowed). sortOrder 0 = primary (org chart + approval chain).
  reportingLinksAsSubordinate UserReportingLink[] @relation("ReportingSubordinate")
  reportingLinksAsManager     UserReportingLink[] @relation("ReportingManager")

  createdTasks       Task[]            @relation("TaskCreator")
  assignedTasks      Task[]            @relation("TaskAssignee")
  createdRecurring   RecurringTask[]   @relation("RecurringCreator")
  assignedRecurring  RecurringTask[]   @relation("RecurringAssignee")
  approvalRequests   ApprovalRequest[] @relation("ApprovalRequester")
  approvals          Approval[]
  taskRequestsSubmitted TaskRequest[]  @relation("TaskRequestRequester")
  taskRequestsToApprove TaskRequest[]    @relation("TaskRequestApprover")
  taskComments       TaskComment[]
  ideas              Idea[]
  userReminders      UserReminder[]
  channelMessages    ChannelMessage[]
  dmChannelsAsLow    Channel[] @relation("ChannelDmLow")
  dmChannelsAsHigh   Channel[] @relation("ChannelDmHigh")
  channelsCreated    Channel[] @relation("ChannelCreatedBy")
  channelMemberships ChannelMember[]
  calendars          CalendarCollection[] @relation("CalendarOwner")
  calendarEntries    CalendarEntry[] @relation("CalendarEntryCreator")
  calendarMembers    CalendarMember[]
  contentEntriesAssigned CalendarEntry[] @relation("ContentEntryAssignee")
  contentEntriesApproved CalendarEntry[] @relation("ContentEntryApprovedBy")
  passwordResetTokens PasswordResetToken[]
  pushSubscriptions   PushSubscription[]
  scheduledPushesCreated ScheduledPush[] @relation("TenantScheduledPushCreator")

  @@unique([email, companyId])
  @@unique([username, companyId])
  @@map("users")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

enum ScheduledPushStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
  CANCELLED
}

model ScheduledPush {
  id                       String              @id @default(cuid())
  companyId                String?
  title                    String
  body                     String
  targetPath               String
  scheduledAt              DateTime
  status                   ScheduledPushStatus @default(PENDING)
  createdByTenantUserId    String?
  createdByPlatformOwnerId String?
  sentAt                   DateTime?
  errorMessage             String?
  recipientCount           Int?
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt

  company           Company?       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdByTenant   User?          @relation("TenantScheduledPushCreator", fields: [createdByTenantUserId], references: [id], onDelete: SetNull)
  createdByPlatform PlatformOwner? @relation(fields: [createdByPlatformOwnerId], references: [id], onDelete: SetNull)

  @@index([status, scheduledAt])
  @@index([companyId])
  @@map("scheduled_pushes")
}

/// Many-to-many: a subordinate can report to multiple managers. sortOrder 0 = primary.
model UserReportingLink {
  id            String   @id @default(cuid())
  companyId     String
  subordinateId String
  managerId     String
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  subordinate User    @relation("ReportingSubordinate", fields: [subordinateId], references: [id], onDelete: Cascade)
  manager     User    @relation("ReportingManager", fields: [managerId], references: [id], onDelete: Cascade)

  @@unique([subordinateId, managerId])
  @@index([companyId, managerId])
  @@index([companyId, subordinateId])
  @@map("user_reporting_links")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

// ─── Personal reminders (dashboard / exec workflow) ───────────────────────

model UserReminder {
  id        String   @id @default(cuid())
  companyId String
  userId    String
  title     String
  note      String?
  remindAt  DateTime
  isDone    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId, userId])
  @@index([userId, remindAt])
  @@map("user_reminders")
}

model CalendarCollection {
  id          String       @id @default(cuid())
  companyId   String
  ownerUserId String?
  name        String
  color       String       @default("#22c55e")
  type        CalendarType @default(PERSONAL)
  contentChannel String?
  /// Readymade platform (linkedin, instagram, …) for AI format/tone; custom uses contentChannel label.
  contentPlatformPreset String?
  isArchived  Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  owner   User?   @relation("CalendarOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  entries CalendarEntry[]
  members CalendarMember[]

  @@index([companyId, type, isArchived])
  @@index([ownerUserId, isArchived])
  @@map("calendar_collections")
}

enum CalendarMemberRole {
  VIEW
  EDIT
  PUBLISH
  ADMIN
}

model CalendarMember {
  id         String             @id @default(cuid())
  calendarId String
  userId     String
  role       CalendarMemberRole @default(EDIT)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  calendar CalendarCollection @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([calendarId, userId])
  @@index([userId])
  @@map("calendar_members")
}

model CalendarEntry {
  id          String            @id @default(cuid())
  companyId   String
  calendarId  String
  creatorId   String
  title       String
  notes       String?
  kind        CalendarEntryKind @default(GOAL)
  color       String            @default("#22c55e")
  startAt     DateTime
  endAt       DateTime?
  isDone      Boolean           @default(false)
  contentStatus ContentEntryStatus?
  assigneeId    String?
  url           String?
  approvedById  String?
  approvedAt    DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  company  Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  calendar CalendarCollection @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  creator  User               @relation("CalendarEntryCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  assignee User?              @relation("ContentEntryAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  approvedBy User?            @relation("ContentEntryApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([companyId, startAt])
  @@index([calendarId, startAt])
  @@index([assigneeId])
  @@map("calendar_entries")
}

enum CalendarType {
  ORG
  PERSONAL
  CHANNEL
}

enum CalendarEntryKind {
  GOAL
  MILESTONE
  CONTENT
}

enum ContentEntryStatus {
  IDEA
  DRAFT
  IN_REVIEW
  APPROVED
  READY_TO_PUBLISH
  PUBLISHED
  CANCELLED
}

// ─── Tasks ──────────────────────────────────────────────────────────────────

model Task {
  id          String   @id @default(cuid())
  companyId   String
  creatorId   String
  assigneeId  String
  title       String
  description String?
  status      String   @default("TODO")
  priority    Priority @default(MEDIUM)
  dueDate     DateTime?
  completedAt DateTime?
  isArchived  Boolean    @default(false)
  recurringId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company     Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  creator     User           @relation("TaskCreator", fields: [creatorId], references: [id])
  assignee    User           @relation("TaskAssignee", fields: [assigneeId], references: [id])
  recurring   RecurringTask? @relation(fields: [recurringId], references: [id])
  attachments  Attachment[]
  comments     TaskComment[]
  taskRequestCreated TaskRequest?

  @@map("tasks")
}

// ─── Task Status Config (per-company custom statuses) ───────────────────────

model TaskStatusConfig {
  id        String     @id @default(cuid())
  companyId String
  key       String     // stored in Task.status (e.g. "TODO", "MY_STATUS_1")
  label     String     // display name (e.g. "To Do", "Backlog")
  color     String     @default("#64748b")
  order     Int
  type      StatusType @default(ACTIVE)

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, key])
  @@unique([companyId, order])
  @@map("task_status_configs")
}

enum StatusType {
  OPEN    // Initial state — tasks start here
  ACTIVE  // In-progress states (can have multiple)
  REVIEW  // Assignee submits here; creator/higher approves
  DONE    // Final state — triggers archiving
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ─── Task approval requests (manager approves before task exists) ─────────

model TaskRequest {
  id          String            @id @default(cuid())
  companyId   String
  requesterId String
  approverId  String
  title       String
  description String?
  priority    Priority          @default(MEDIUM)
  dueDate     DateTime?
  status      TaskRequestStatus @default(PENDING)

  attachmentFileUrl    String?
  attachmentFileName   String?
  attachmentMimeType   String?
  attachmentFileSize   Int?

  createdTaskId      String? @unique
  approverAssigneeId String?
  rejectComment      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  requester User    @relation("TaskRequestRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  approver  User    @relation("TaskRequestApprover", fields: [approverId], references: [id], onDelete: Cascade)
  createdTask Task? @relation(fields: [createdTaskId], references: [id], onDelete: SetNull)

  @@index([companyId, status])
  @@index([approverId, status])
  @@map("task_requests")
}

enum TaskRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── Recurring Tasks ────────────────────────────────────────────────────────

model RecurringTask {
  id          String    @id @default(cuid())
  companyId   String
  creatorId   String
  assigneeId  String
  title       String
  description String?
  priority    Priority  @default(MEDIUM)
  frequency   Frequency
  daysOfWeek  Int[]
  dayOfMonth  Int?
  startDate   DateTime  @default(now())
  endDate     DateTime?
  templateAttachments Json      @default("[]")
  isActive    Boolean   @default(true)
  lastGenerated DateTime?
  nextDue     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company  Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  creator  User    @relation("RecurringCreator", fields: [creatorId], references: [id])
  assignee User    @relation("RecurringAssignee", fields: [assigneeId], references: [id])
  tasks    Task[]

  @@map("recurring_tasks")
}

enum Frequency {
  DAILY
  WEEKLY
  MONTHLY
}

// ─── Approval Requests ──────────────────────────────────────────────────────

model ApprovalRequest {
  id            String         @id @default(cuid())
  companyId     String
  requesterId   String
  newUserData   Json
  approverChain Json           @default("[]")  // ordered array of user IDs: [directParentId, ..., rootId]
  status        ApprovalStatus @default(PENDING)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  requester User       @relation("ApprovalRequester", fields: [requesterId], references: [id])
  approvals Approval[]

  @@map("approval_requests")
}

model Approval {
  id         String         @id @default(cuid())
  requestId  String
  approverId String
  status     ApprovalStatus @default(PENDING)
  comment    String?
  createdAt  DateTime       @default(now())

  request  ApprovalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  approver User            @relation(fields: [approverId], references: [id], onDelete: Cascade)

  @@map("approvals")
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── Task Comments ──────────────────────────────────────────────────────────

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  authorId  String
  body      String
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@map("task_comments")
}

// ─── Team Chat Channels ───────────────────────────────────────────────────────

model Channel {
  id          String   @id @default(cuid())
  companyId   String
  slug        String
  name        String
  type        ChannelType @default(GLOBAL) // GLOBAL | ROLE | CUSTOM | DM | GROUP
  roleLevelId String?
  /// For type DM only: participant ids sorted lexicographically (low before high).
  dmUserLowId  String?
  dmUserHighId String?
  /// For type GROUP: user who created the group (optional audit).
  createdById String?
  /// For type GROUP: optional photo shown in chat list and header.
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company    Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  roleLevel  RoleLevel?       @relation(fields: [roleLevelId], references: [id])
  dmUserLow  User?            @relation("ChannelDmLow", fields: [dmUserLowId], references: [id], onDelete: Cascade)
  dmUserHigh User?            @relation("ChannelDmHigh", fields: [dmUserHighId], references: [id], onDelete: Cascade)
  createdBy  User?            @relation("ChannelCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  messages   ChannelMessage[]
  members    ChannelMember[]

  @@unique([companyId, slug])
  @@index([companyId, dmUserLowId])
  @@index([companyId, dmUserHighId])
  @@index([companyId, createdById])
  @@map("channels")
}

model ChannelMember {
  id        String            @id @default(cuid())
  companyId String
  channelId String
  userId    String
  /// GROUP channels: admins can rename the group, add/remove members, and assign admin.
  role      ChannelMemberRole @default(MEMBER)
  createdAt DateTime          @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([companyId, userId])
  @@index([channelId])
  @@map("channel_members")
}

enum ChannelMemberRole {
  MEMBER
  ADMIN
}

model ChannelMessage {
  id        String   @id @default(cuid())
  companyId String
  channelId String
  authorId  String
  body      String   @default("")
  /// JSON array: { url, kind: "image"|"video", mimeType, fileName? }[]
  attachments Json   @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([companyId, channelId, createdAt])
  @@map("channel_messages")
}

enum ChannelType {
  GLOBAL
  ROLE
  CUSTOM
  DM
  GROUP
}

// ─── Ideas (Brain Dump Board) ────────────────────────────────────────────────

model Idea {
  id          String      @id @default(cuid())
  companyId   String
  userId      String
  title       String
  body        String?
  color       String      @default("#6366f1")
  /// JSON array: { name: string, color: string }[]
  tags        Json        @default("[]")
  /// JSON array: { id: string, title: string, content: string, updatedAt: string }[]
  pages       Json        @default("[]")
  status      IdeaStatus  @default(IDEA)
  convertedTaskId String?
  /// JSON array of task ids created from this idea.
  convertedTaskIds Json    @default("[]")
  isPinned    Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ideas")
}

enum IdeaStatus {
  IDEA
  THINKING
  CONVERTED
  DROPPED
}

// ─── Attachments ────────────────────────────────────────────────────────────

model Attachment {
  id         String   @id @default(cuid())
  taskId     String
  fileName   String
  fileUrl    String
  fileSize   Int
  mimeType   String
  uploaderId String
  createdAt  DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("attachments")
}

// ─── Billing ────────────────────────────────────────────────────────────────

// Global singleton — platform owner configures default pricing here.
// id is always "default"; upsert is safe at any time.
model BillingConfig {
  id                 String   @id @default("default")
  defaultPricePerSeat Float   @default(0)
  currency           String   @default("USD")
  billingCycle       String   @default("monthly") // monthly | annual
  updatedAt          DateTime @updatedAt

  @@map("billing_config")
}

// One row per company — created lazily on first edit.
// pricePerSeat null = inherit from BillingConfig.defaultPricePerSeat
model CompanyBilling {
  id                 String    @id @default(cuid())
  companyId          String    @unique
  plan               String    @default("FREE")    // FREE | STARTER | PRO | ENTERPRISE
  pricePerSeat       Float?                         // null = use platform default
  aiAddonEnabled     Boolean   @default(false)
  aiPricePerSeat     Float?
  chatAddonEnabled   Boolean   @default(false)
  chatPricePerSeat   Float?
  recurringAddonEnabled Boolean @default(false)
  recurringPricePerSeat Float?
  contentStudioAddonEnabled Boolean @default(false)
  contentStudioPricePerSeat Float?
  seatsLimit         Int?                           // null = unlimited
  billingEmail       String?
  notes              String?
  trialEndsAt        DateTime?
  subscriptionId     String?                        // future: Stripe subscription ID
  subscriptionStatus String    @default("active")  // active | trialing | past_due | canceled
  /// Stripe current_period_end (access until this instant for canceled subs)
  subscriptionCurrentPeriodEnd DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_billing")
}

model TenantInfraConfig {
  id                   String   @id @default(cuid())
  companyId            String   @unique
  deploymentMode       DeploymentMode @default(SHARED)
  provisioningStatus   ProvisioningStatus @default(PENDING)
  provisioningError    String?

  // Dedicated/shared runtime targets
  backendBaseUrl       String?
  backendIp            String?
  frontendBaseUrl      String?
  frontendIp           String?

  // DB metadata (secret refs, not plaintext creds)
  dbHost               String?
  dbPort               Int?
  dbName               String?
  dbUserSecretRef      String?
  dbPasswordSecretRef  String?
  dbUrlSecretRef       String?

  // AI isolation per tenant
  aiProvider           String?   // gemini | openai | custom
  aiModel              String?
  aiApiKeySecretRef    String?
  aiBaseUrl            String?
  aiRequestBudgetDaily Int?
  aiRequestCountDaily  Int       @default(0)
  aiBudgetResetAt      DateTime?

  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([provisioningStatus, updatedAt])
  @@map("tenant_infra_configs")
}

model TenantProvisioningJob {
  id                String   @id @default(cuid())
  companyId         String
  action            ProvisioningAction
  status            ProvisioningStatus @default(PENDING)
  idempotencyKey    String?
  attempts          Int      @default(0)
  maxAttempts       Int      @default(3)
  lastError         String?
  payload           Json?
  startedAt         DateTime?
  finishedAt        DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, status, createdAt])
  @@map("tenant_provisioning_jobs")
}

model TenantAiUsageLog {
  id            String   @id @default(cuid())
  companyId     String
  endpoint      String
  provider      String?
  model         String?
  requestCount  Int      @default(1)
  estimatedCost Float?
  createdAt     DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
  @@map("tenant_ai_usage_logs")
}

/// Ephemeral payload between Stripe Checkout creation and webhook completion (self-service signup).
model PendingTenantSignup {
  id                String   @id @default(cuid())
  stripeSessionId   String?  @unique
  payload           Json
  createdAt         DateTime @default(now())

  @@map("pending_tenant_signups")
}

/// One row per email: workspace signup email verification OTP (replaced on each resend).
model WorkspaceSignupOtp {
  id        String   @id @default(cuid())
  email     String   @unique
  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@map("workspace_signup_otps")
}

model ProcessedStripeEvent {
  id        String   @id
  createdAt DateTime @default(now())

  @@map("processed_stripe_events")
}

enum DeploymentMode {
  SHARED
  DEDICATED
}

enum ProvisioningStatus {
  PENDING
  PROVISIONING
  READY
  FAILED
}

enum ProvisioningAction {
  PROVISION
  REPROVISION
  VALIDATE
}
