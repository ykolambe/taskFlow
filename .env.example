# Database - PostgreSQL connection URL (required: must start with postgresql:// or postgres://)
# If db push fails with P1012, this variable is missing, empty, or uses the wrong scheme.
DATABASE_URL="postgresql://postgres:password@localhost:5432/taskmanager"

# JWT Secret - change this to a strong random string in production
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# Root domain for subdomain routing (host:port or hostname only)
# Local dev: localhost:3000
# ngrok / tunnel: use your public hostname only, e.g. abc123.ngrok-free.app (no https://)
# Production: yourdomain.com
ROOT_DOMAIN="localhost:3000"

# Platform owner credentials (used only for initial seed)
PLATFORM_EMAIL="admin@platform.com"
PLATFORM_PASSWORD="Platform@123"
PLATFORM_NAME="Platform Admin"

# Public base URL (scheme + host, optional port). Used for defaults and redirects.
# Local: http://localhost:3000
# ngrok: https://YOUR-SUBDOMAIN.ngrok-free.app (match the URL you open in the browser)
NEXTAUTH_URL="http://localhost:3000"

# Same as NEXTAUTH_URL for email links and Stripe success/cancel when request has no Host (optional)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Self-service signup (Free workspace or Stripe Pro checkout + webhook). Leave false until configured.
PUBLIC_SIGNUP_ENABLED="false"

# Plan limits — Free tier seat cap (Pro is unlimited; bill per seat in Stripe)
FREE_PLAN_SEAT_LIMIT="5"

# Display labels on /signup (optional)
NEXT_PUBLIC_PRO_PRICE_LABEL="$29/mo"
NEXT_PUBLIC_ADDON_CHAT_LABEL="+$10/mo each"
NEXT_PUBLIC_ADDON_RECURRING_LABEL="+$8/mo each"
NEXT_PUBLIC_ADDON_AI_LABEL="+$15/mo each"

# Stripe (test keys in development). Create Products/Prices in Stripe Dashboard.
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_BASE_SUBSCRIPTION=""
STRIPE_PRICE_ADDON_CHAT=""
STRIPE_PRICE_ADDON_RECURRING=""
STRIPE_PRICE_ADDON_AI=""

# Transactional email (password reset, etc.) via Resend — https://resend.com/api-keys
# RESEND_API_KEY: create in Resend dashboard (starts with re_).
# EMAIL_FROM: must be allowed by Resend — use "TaskFlow <onboarding@resend.dev>" for quick tests,
# or verify your domain in Resend and use e.g. "TaskFlow <noreply@yourdomain.com>".
RESEND_API_KEY=""
EMAIL_FROM="TaskFlow <onboarding@resend.dev>"

# Auth cookies: Secure flag is set automatically on HTTPS (ngrok) and in production.
# Optional override: COOKIE_SECURE=true | false
# COOKIE_SECURE=

# ─── File Storage ────────────────────────────────────────────────────────────
# STORAGE_PROVIDER: "local" (default) OR "s3"
# Leave unset or set to "local" to save uploads to public/uploads on disk.
# Set to "s3" to use AWS S3 or any S3-compatible service (DigitalOcean Spaces,
# Cloudflare R2, MinIO, Backblaze B2, etc.)
STORAGE_PROVIDER="local"

# S3 / DigitalOcean Spaces / MinIO (only needed when STORAGE_PROVIDER=s3)
S3_BUCKET="your-bucket-name"
S3_REGION="us-east-1"                          # AWS region, or DO Spaces region e.g. "nyc3"
S3_ACCESS_KEY_ID="your-access-key-id"
S3_SECRET_ACCESS_KEY="your-secret-access-key"

# Optional: custom endpoint for non-AWS S3-compatible services
# DigitalOcean Spaces:  https://nyc3.digitaloceanspaces.com
# MinIO (local):        http://localhost:9000
# Leave blank for AWS S3
S3_ENDPOINT=""

# Optional: public base URL for serving files.
# DigitalOcean Spaces CDN:  https://your-bucket.nyc3.cdn.digitaloceanspaces.com
# Leave blank to auto-derive from S3_BUCKET + S3_REGION (AWS default).
S3_PUBLIC_URL=""

# Gemini API key for Executive AI Brief
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"

# Optional: job runner token for /api/platform/provisioning/run
PROVISIONING_RUN_TOKEN=""

# Optional: JSON map for secret refs -> values
# Example: {"tenantA-gemini-key":"AIza...","tenantA-db-password":"..."}
TENANT_SECRET_REF_MAP_JSON=""

# Per-tenant DB URL refs (e.g. TENANT_ACME_DATABASE_URL) must be the FULL connection string
# starting with postgresql:// or postgres:// — or omit and set PG_SHARED_DEFAULT_* + host/name
# below so provisioning can build the URL. If unset, the ref name alone is NOT a valid URL
# and Prisma will fail with P1012 during db_bootstrap.

# ─── Tenant DB Provisioning Bootstrap ────────────────────────────────────────
# Postgres admin/superuser URL used only by provisioning worker to create DBs.
# Must point to a control DB like "postgres", not a tenant DB.
PG_ADMIN_URL="postgresql://postgres:1234@localhost:5432/postgres"
PG_SHARED_DEFAULT_DB_USER=postgres
PG_SHARED_DEFAULT_DB_PASSWORD=1234
# Optional sslmode appended to constructed tenant DB URLs:
# disable | allow | prefer | require | verify-ca | verify-full
PG_TENANT_SSLMODE="disable"

# Provisioning strategy:
# - migrate: run `prisma migrate deploy` first, fallback to `prisma db push`
# - dbpush: run `prisma db push` only
PG_PROVISION_PRISMA_STRATEGY="migrate"

# If true, provisioning will also bootstrap shared-mode tenant DBs.
# Default behavior is to bootstrap DEDICATED only.
PROVISION_SHARED_DB_BOOTSTRAP="false"

# Shared-mode tenant defaults used during company auto-onboarding
PG_SHARED_DEFAULT_HOST="localhost"
PG_SHARED_DEFAULT_PORT="5432"
SHARED_BACKEND_BASE_URL="http://localhost:3000"
SHARED_FRONTEND_BASE_URL="http://localhost:3000"
SHARED_AI_PROVIDER="gemini"
SHARED_AI_MODEL="gemini-2.0-flash"
PG_SHARED_DEFAULT_DB_USER="postgres"
PG_SHARED_DEFAULT_DB_PASSWORD="password"
