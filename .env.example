# Database - PostgreSQL connection URL
DATABASE_URL="postgresql://postgres:password@localhost:5432/taskmanager"

# JWT Secret - change this to a strong random string in production
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# Root domain for subdomain routing
# Local dev: localhost:3000
# Production: yourdomain.com
ROOT_DOMAIN="localhost:3000"

# Platform owner credentials (used only for initial seed)
PLATFORM_EMAIL="admin@platform.com"
PLATFORM_PASSWORD="Platform@123"
PLATFORM_NAME="Platform Admin"

# Next.js public URL
NEXTAUTH_URL="http://localhost:3000"

# ─── File Storage ────────────────────────────────────────────────────────────
# STORAGE_PROVIDER: "local" (default) OR "s3"
# Leave unset or set to "local" to save uploads to public/uploads on disk.
# Set to "s3" to use AWS S3 or any S3-compatible service (DigitalOcean Spaces,
# Cloudflare R2, MinIO, Backblaze B2, etc.)
STORAGE_PROVIDER="local"

# S3 / DigitalOcean Spaces / MinIO (only needed when STORAGE_PROVIDER=s3)
S3_BUCKET="your-bucket-name"
S3_REGION="us-east-1"                          # AWS region, or DO Spaces region e.g. "nyc3"
S3_ACCESS_KEY_ID="your-access-key-id"
S3_SECRET_ACCESS_KEY="your-secret-access-key"

# Optional: custom endpoint for non-AWS S3-compatible services
# DigitalOcean Spaces:  https://nyc3.digitaloceanspaces.com
# MinIO (local):        http://localhost:9000
# Leave blank for AWS S3
S3_ENDPOINT=""

# Optional: public base URL for serving files.
# DigitalOcean Spaces CDN:  https://your-bucket.nyc3.cdn.digitaloceanspaces.com
# Leave blank to auto-derive from S3_BUCKET + S3_REGION (AWS default).
S3_PUBLIC_URL=""
